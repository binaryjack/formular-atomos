{
  "name": "@formular/atomos",
  "version": "0.1.0",
  "description": "React form components bridging Atomos UI and Formular.dev validation",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "demo": "cd demo && pnpm dev",
    "demo:build": "cd demo && pnpm build",
    "demo:start": "cd demo && pnpm start",
    "deploy:showcase": "cd packages/showcase && pnpm build && cd ../.. && rm -rf docs && mv packages/showcase/out docs && echo > docs/.nojekyll",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext ts,tsx",
    "type-check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "keywords": [
    "react",
    "forms",
    "validation",
    "atomos",
    "formular",
    "components",
    "typescript",
    "ui"
  ],
  "author": "BinaryJack",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/binaryjack/formular-atomos.git"
  },
  "peerDependencies": {
    "@atomos/ui": "workspace:*",
    "formular.dev": "workspace:*",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "peerDependenciesMeta": {
    "@atomos/ui": {
      "optional": true
    },
    "formular.dev": {
      "optional": true
    }
  },
  "devDependencies": {
    "@atomos/ui": "workspace:*",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.42",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^1.6.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "formular.dev": "npm:@binaryjack/formular.dev@^2.1.1",
    "happy-dom": "^12.10.3",
    "postcss": "^8.5.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@binaryjack/formular.dev": "^2.1.1"
  }
}
