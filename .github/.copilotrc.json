{
  "$schema": "https://github.com/github/copilot-instructions/blob/main/schemas/copilot-instructions.schema.json",
  "version": "1.0.0",
  "project": "@formular/atomos",
  "description": "Enterprise form component library bridging Atomos UI and Formular.dev validation",
  
  "agents": {
    "formular-atomos-business": {
      "name": "Formular-Atomos Business Specialist",
      "description": "Domain expert for form validation business logic and functional requirements",
      "instructionsFile": ".github/copilot-instructions/formular-atomos-business-specialist.md",
      "triggers": [
        "form validation",
        "business requirements",
        "field schema",
        "validation rules",
        "user story",
        "multi-language",
        "country-specific",
        "accessibility requirements"
      ],
      "delegatesTo": [
        "react-typescript-specialist",
        "state-management-specialist",
        "accessibility-specialist",
        "testing-specialist"
      ],
      "requiredRules": [
        ".github/copilot-starter-kit/.copilot-rules.json",
        "ATOMOS_INTEGRATION.md"
      ],
      "isDefault": true
    }
  },
  
  "rules": {
    "namingConventions": {
      "components": "PascalCase",
      "files": "kebab-case",
      "fields": "camelCase",
      "propsInterfaces": "I{ComponentName}Props",
      "hooks": "use{Name}",
      "hookFiles": "use-{name}.ts"
    },
    
    "architecture": {
      "maxComponentLines": 200,
      "extractThreshold": 150,
      "oneConceptPerFile": true,
      "noMagicStrings": true,
      "strictTypeScript": true
    },
    
    "validation": {
      "simpleRules": "Atomos validators (required, minLength, maxLength, pattern)",
      "advancedRules": "Formular validators (email, phone, ssn, postal, custom)",
      "strategy": "Use Atomos for UI-level, Formular for domain validation"
    },
    
    "accessibility": {
      "wcagLevel": "AA",
      "mandatoryLabels": true,
      "keyboardNavigation": true,
      "screenReaderSupport": true,
      "ariaAttributes": "required for all form inputs"
    }
  },
  
  "workflows": {
    "createComponent": {
      "agent": "formular-atomos-business",
      "steps": [
        "Define business requirements and field schema",
        "Load .copilot-rules.json and ATOMOS_INTEGRATION.md",
        "Delegate to React specialist with requirements",
        "Verify: <200 lines, type-safe, accessible",
        "Update ATOMOS_INTEGRATION.md documentation"
      ]
    },
    
    "addValidation": {
      "agent": "formular-atomos-business",
      "steps": [
        "Document validation rules for country/type",
        "Define error messages in 6 languages",
        "Delegate to validation specialist",
        "Create example usage",
        "Update API reference documentation"
      ]
    },
    
    "beforeAnyCode": {
      "mandatory": true,
      "checklist": [
        "Read .github/copilot-starter-kit/.copilot-rules.json",
        "Read ATOMOS_INTEGRATION.md (relevant sections)",
        "Verify naming conventions (camelCase fields, kebab-case files)",
        "Confirm component will be <200 lines",
        "Define accessibility requirements",
        "Specify validation strategy (Atomos vs Formular)"
      ]
    }
  },
  
  "communication": {
    "style": "concise",
    "brevity": "1-3 sentences for simple answers",
    "noEmojis": true,
    "noFraming": true,
    "demandClarityOnViolations": true
  },
  
  "documentation": {
    "mainFile": "ATOMOS_INTEGRATION.md",
    "updateOn": [
      "new component creation",
      "new validation type",
      "API changes",
      "breaking changes"
    ],
    "requiredSections": [
      "API Reference",
      "Complete Examples",
      "Best Practices"
    ]
  }
}
